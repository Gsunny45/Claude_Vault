# Caddy reverse proxy config
# Replace YOUR_DOMAIN with your actual domain or use the Hostinger subdomain
# For IP-only access, use :80 instead of the domain

{$DOMAIN:peachpuff-newt-682861.hostingorsite.com} {
    # React frontend (default)
    handle {
        reverse_proxy frontend:80
    }

    # API routes → FastAPI backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # n8n at /n8n/ path
    handle /n8n/* {
        uri strip_prefix /n8n
        reverse_proxy n8n:5678
    }

    # n8n webhooks (n8n needs these at root for external triggers)
    handle /webhook/* {
        reverse_proxy n8n:5678
    }
    handle /webhook-test/* {
        reverse_proxy n8n:5678
    }
}
