{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Total Notes by Vault",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(vault_notes_total) by (vault)", "legendFormat": "{{vault}}" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Open Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "targets": [{ "expr": "sum(vault_tasks_total{status=~'open|in_progress'})", "legendFormat": "Open" }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "#FF9830", "mode": "fixed" }, "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 3}, {"color": "red", "value": 10}] } } }
    },
    {
      "title": "Drift Issues",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "targets": [{ "expr": "sum(vault_drift_issues_total)", "legendFormat": "Issues" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}] } } }
    },
    {
      "title": "Knowledge Health",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "vault_knowledge_verified_total", "legendFormat": "Verified" },
        { "expr": "vault_knowledge_stale_total", "legendFormat": "Stale" },
        { "expr": "vault_knowledge_inferred_total", "legendFormat": "Inferred" }
      ]
    },
    {
      "title": "Stale Notes (>14 days)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 0 },
      "targets": [{ "expr": "vault_stale_notes_total", "legendFormat": "{{vault}}" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 5}, {"color": "red", "value": 15}] } } }
    },
    {
      "title": "Notes by Folder",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{ "expr": "vault_notes_total{vault='claude_vault'}", "legendFormat": "{{folder}}" }],
      "options": { "orientation": "horizontal" }
    },
    {
      "title": "Task Pipeline",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "targets": [{ "expr": "vault_tasks_total", "legendFormat": "{{status}}" }],
      "fieldConfig": { "overrides": [
        { "matcher": { "id": "byName", "options": "open" }, "properties": [{ "id": "color", "value": { "fixedColor": "#4c9aff", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "in_progress" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e6a700", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ff4444", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "done" }, "properties": [{ "id": "color", "value": { "fixedColor": "#2ea043", "mode": "fixed" } }] }
      ] }
    },
    {
      "title": "Decisions by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "targets": [{ "expr": "vault_decisions_total", "legendFormat": "{{status}}" }]
    },
    {
      "title": "Drift Issues by Severity",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 12 },
      "targets": [{ "expr": "vault_drift_issues_total", "legendFormat": "{{severity}}" }],
      "fieldConfig": { "overrides": [
        { "matcher": { "id": "byName", "options": "critical" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ff0000", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "high" }, "properties": [{ "id": "color", "value": { "fixedColor": "#ff8c00", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "medium" }, "properties": [{ "id": "color", "value": { "fixedColor": "#e6a700", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "low" }, "properties": [{ "id": "color", "value": { "fixedColor": "#4c9aff", "mode": "fixed" } }] }
      ] }
    },
    {
      "title": "Sessions (Last 7 Days)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 12 },
      "targets": [{ "expr": "vault_sessions_last_7_days", "legendFormat": "{{vault}}" }]
    },
    {
      "title": "Vault Size (MB)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 12 },
      "targets": [{ "expr": "vault_total_size_bytes / 1024 / 1024", "legendFormat": "{{vault}}" }],
      "fieldConfig": { "defaults": { "unit": "decmbytes" } }
    },
    {
      "title": "Oldest Open Task (Days)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 12 },
      "targets": [{ "expr": "vault_tasks_oldest_open_days", "legendFormat": "{{vault}}" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 7}, {"color": "red", "value": 30}] }, "min": 0, "max": 60 } }
    }
  ],
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["vault", "obsidian", "claude"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Vault Operations Dashboard",
  "uid": "vault-ops-001"
}
