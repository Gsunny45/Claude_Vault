{
  "files.exclude": {
    "**/.obsidian": true,
    "**/node_modules": true,
    "**/.smart-env": true,
    "**/__pycache__": true,
    "**/.git": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.obsidian/plugins/*/main.js": true,
    "**/.git": true
  },
  "python.defaultInterpreterPath": "python",
  "python.analysis.typeCheckingMode": "basic",
  "[python]": {
    "editor.formatOnSave": true
  },
  "files.associations": {
    "*.md": "markdown"
  },
  "editor.formatOnSave": false,
  "yaml.schemas": {
    "./_system/_schemas.yaml": "*.yaml"
  }
}
